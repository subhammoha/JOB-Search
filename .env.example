# Job Search API Keys
# Copy this file to .env.local and fill in your keys

# JSearch via RapidAPI — covers LinkedIn, Indeed, Glassdoor, ZipRecruiter
# Sign up at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_RAPIDAPI_KEY=

# Adzuna — US/UK/AU job listings
# Register at: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# The Muse — optional, increases rate limit from 500 to 3600 req/hr
# Register at: https://www.themuse.com/developers/api/v2
THEMUSE_API_KEY=

# Enabled sources (comma-separated) — leave empty to enable all
# Available: arbeitnow,remotive,adzuna,themuse,jsearch
ENABLED_SOURCES=

# Enable live H1B lookup fallback (default: false)
H1B_LIVE_LOOKUP=false
